        )
        {
            point3f physics:centerOfMass = (0, 0, 0)
            float3 physics:diagonalInertia = (0.00001248, 0.0000624, 0.0000624)
            float physics:mass = 0.1872
            quatf physics:principalAxes = (0.95857674, 0.12524493, 0.22459254, -0.12248472)
