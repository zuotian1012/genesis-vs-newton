            float3 xformOp:rotateXYZ = (0, 0, 0)
            double3 xformOp:translate = (-0.049999999999999926, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]

            def Scope "Geometry"
            {
                def Scope "Primary"
                {
                    def "mesh_0" (
