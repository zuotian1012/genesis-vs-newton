#usda 1.0
(
    defaultPrim = "test_fixed"
    kilogramsPerUnit = 1
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "test_fixed"
{
    def Scope "RigidBodies"
    {
        def Xform "rb_a" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
            customData = {
