                        customData = {
                            string layer = "Primary"
                            string uuid = "d5e61067-93d0-4f01-b1ea-1b139c135ff5"
                        }
                        prepend references = @Geometry/surfaces.usd@</Surfaces/mesh_d5e61067_93d0_4f01_b1ea_1b139c135ff5>
                    )
                    {
                        float3 xformOp:rotateXYZ = (0, 0, 0)
                        double3 xformOp:translate = (0, 0, 0)
                        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
                    }
                }
            }
        }
    }

    def Scope "FlexibleBodies"
    {
    }

    def Scope "Joints"
    {
        def PhysicsFixedJoint "rb_a" (
            customData = {
                string uuid = "fa1b4a3c-ce8e-4cf6-92c5-c10591b98139"
            }
        )
        {
            rel physics:body1 = </test_fixed/RigidBodies/rb_a>
            point3f physics:localPos0 = (-0.05, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
