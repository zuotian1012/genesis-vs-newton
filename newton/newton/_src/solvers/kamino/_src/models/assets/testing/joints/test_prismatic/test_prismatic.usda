                            string uuid = "122df4b1-cd46-4c84-a96f-2395e0d850b8"
                        }
                        prepend references = @Geometry/surfaces.usd@</Surfaces/mesh_122df4b1_cd46_4c84_a96f_2395e0d850b8>
                    )
                    {
                        float3 xformOp:rotateXYZ = (0, 0, 0)
                        double3 xformOp:translate = (0, 0, 0)
