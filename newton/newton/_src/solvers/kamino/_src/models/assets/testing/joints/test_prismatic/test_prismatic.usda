    }

    def Scope "Joints"
    {
        def PhysicsFixedJoint "rb_a" (
            customData = {
                string uuid = "f700677f-7613-455d-801f-26da1c6c6357"
            }
        )
        {
            rel physics:body1 = </test_prismatic/RigidBodies/rb_a>
            point3f physics:localPos0 = (-0.015560065, -0.084845915, -0.005744456)
            point3f physics:localPos1 = (0, 0, 0)
