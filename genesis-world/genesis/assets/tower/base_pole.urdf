<?xml version="1.0" encoding="utf-8"?>
<robot name="base_pole">
  <link name="world"/>
  <joint name="world_to_base_pole" type="floating">
    <parent link="world"/>
    <child link="base_pole"/>
  </joint>
  <link name="base_pole">
    <inertial>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="base_pole.glb" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="base_pole.glb" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
</robot>
