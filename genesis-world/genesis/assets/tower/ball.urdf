<?xml version="1.0" encoding="utf-8"?>
<robot name="ball">
  <link name="world"/>
  <joint name="world_to_ball" type="floating">
    <parent link="world"/>
    <child link="ball"/>
  </joint>
  <link name="ball">
    <inertial>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="ball.glb" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="ball_coll.glb" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
</robot>
